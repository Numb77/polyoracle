# ─────────────────────────────────────────────────────────────────────────────
#  PolyOracle — environment configuration template
#  Copy to .env and fill in your values.
#  NEVER commit .env — it contains your private key.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paper trading (safe default) ─────────────────────────────────────────────
PAPER_MODE=true
PAPER_INITIAL_BALANCE=1000.0

# ── Wallet (required for live trading only) ───────────────────────────────────
# Your Polygon wallet private key (with or without 0x prefix)
PRIVATE_KEY=
# The wallet address that holds USDC on Polygon
FUNDER_ADDRESS=
# 0 = EOA/MetaMask wallet, 1 = Magic/Email wallet
SIGNATURE_TYPE=0

# ── Polymarket CLOB API credentials ──────────────────────────────────────────
# Generated by: python scripts/setup_wallet.py
# Leave blank for paper trading.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# ── Strategy parameters ───────────────────────────────────────────────────────
TRADE_AMOUNT_USD=10.0
MAX_TRADE_AMOUNT_USD=10.0
MIN_CONFIDENCE_SCORE=65
MIN_TOKEN_PRICE=0.30
MAX_TOKEN_PRICE=0.80
MIN_WINDOW_DELTA_PCT=0.005
MIN_TRADE_EDGE=0.02
ENTRY_WINDOW_START_SEC=295
TRADING_WINDOW_START_SEC=270
ENTRY_DEADLINE_SEC=90
GTC_WINDOW_SEC=120
MAX_CONCURRENT_POSITIONS=2
MAX_EXPOSURE_USD=500.0

# ── Risk management ───────────────────────────────────────────────────────────
MAX_DAILY_LOSS_USD=50.0
MAX_DRAWDOWN_PCT=35.0
MAX_CONSECUTIVE_LOSSES=5
KELLY_FRACTION=0.25
MIN_USDC_BALANCE=20.0

# ── Infrastructure (defaults are fine for local dev) ─────────────────────────
WS_SERVER_PORT=8765
DASHBOARD_PORT=3000
LOG_LEVEL=INFO
LOG_FILE=logs/polyoracle.log
