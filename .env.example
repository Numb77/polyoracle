# === WALLET (CRITICAL — NEVER EXPOSE) ===
PRIVATE_KEY=0x...your_polygon_private_key
FUNDER_ADDRESS=0x...your_polymarket_deposit_address
SIGNATURE_TYPE=0  # 0=EOA/MetaMask, 1=Magic/Email

# === POLYMARKET ===
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYGON_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com

# === MARKET DATA ===
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
BINANCE_REST_URL=https://api.binance.com
CHAINLINK_BTC_USD_PROXY=0xc907E116054Ad103354f2D350FD2514433D57F6f

# === STRATEGY PARAMETERS ===
TRADE_AMOUNT_USD=50.0               # Base bet size in USDC
MIN_CONFIDENCE_SCORE=30             # Minimum confidence (0-100) to place trade
MIN_TOKEN_PRICE=0.3                # Don't buy tokens below this
MAX_TOKEN_PRICE=0.95                # Don't buy tokens above this
ENTRY_WINDOW_START_SEC=45           # Start evaluating at T-30s
ENTRY_DEADLINE_SEC=5                # Hard deadline: must fire by T-5s
MAX_CONCURRENT_POSITIONS=3          # Max open positions at once

# === RISK MANAGEMENT ===
MAX_DAILY_LOSS_USD=500.0             # Circuit breaker: max loss per day
MAX_DRAWDOWN_PCT=15.0               # Circuit breaker: max drawdown from peak
MAX_CONSECUTIVE_LOSSES=5            # Pause after N consecutive losses
KELLY_FRACTION=0.25                 # Fraction of Kelly criterion (conservative)
MIN_USDC_BALANCE=50.0               # Stop trading if balance drops below this

# === PAPER TRADING ===
PAPER_MODE=true                     # Set to false for live trading
PAPER_INITIAL_BALANCE=1000.0        # Simulated starting balance

# === DASHBOARD ===
WS_SERVER_PORT=8765                 # WebSocket server port for frontend
DASHBOARD_PORT=3000                 # Next.js dev server port

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/polyoracle.log
